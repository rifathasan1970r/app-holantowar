{
  "entities": {
    "GalleryCategory": {
      "title": "Gallery Category",
      "description": "A category in the gallery with a lock status and images.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bn": { "type": "string" },
        "en": { "type": "string" },
        "icon": { "type": "string" },
        "isLocked": { "type": "boolean" },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sliderImages": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["bn", "en", "icon", "isLocked"]
    },
    "GallerySettings": {
      "title": "Gallery Settings",
      "description": "Global settings for the gallery, like the PIN.",
      "type": "object",
      "properties": {
        "pin": { "type": "string" }
      },
      "required": ["pin"]
    }
  },
  "firestore": {
    "/gallery_categories": {
      "schema": "GalleryCategory",
      "description": "Collection of gallery categories."
    },
    "/gallery_settings/config": {
      "schema": "GallerySettings",
      "description": "Global configuration for the gallery."
    }
  }
}
